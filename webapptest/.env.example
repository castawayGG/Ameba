# ============================================================
# Required environment variables
# Copy this file to .env and fill in the values
# ============================================================

# Flask
SECRET_KEY=replace-with-a-long-random-string
FLASK_ENV=production
FLASK_DEBUG=0

# Database (PostgreSQL)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://telegram_user:changeme@postgres:5432/telegram_panel
POSTGRES_USER=telegram_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=telegram_panel

# Redis
REDIS_URL=redis://redis:6379/0

# Telegram API credentials (from https://my.telegram.org/apps)
TG_API_ID=0
TG_API_HASH=

# Admin credentials
# Generate password hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Security
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENCRYPTION_KEY=

# Telegram bot notifications (optional)
NOTIFICATION_BOT_TOKEN=
NOTIFICATION_CHAT_ID=

# Rate limits (optional, these are the defaults)
RATE_LIMIT_LOGIN=10 per minute
RATE_LIMIT_CODE_SEND=5 per minute
RATE_LIMIT_CODE_VERIFY=10 per minute
RATE_LIMIT_API=60 per minute

# Proxy settings (optional)
PROXY_ENABLED=false
PROXY_TYPE=socks5
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# Auto proxy refresh interval in hours (optional)
PROXY_REFRESH_HOURS=6
